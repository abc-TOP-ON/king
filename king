local function SaveSettings()
    local data = game:GetService("HttpService"):JSONEncode(Config)
    writefile("MeowHubSettings.json", data)
end

local function LoadSettings()
    if isfile("MeowHubSettings.json") then
        local data = game:GetService("HttpService"):JSONDecode(readfile("MeowHubSettings.json"))
        for category, settings in pairs(data) do
            if Config[category] then
                for setting, value in pairs(settings) do
                    Config[category][setting] = value
                end
            end
        end
        Notify("✅ Settings Loaded!")
    end
end

