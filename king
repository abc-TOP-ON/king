    Notif.Text = Message
    Notif.Font = Enum.Font.GothamBold
    Notif.TextSize = 14
    Instance.new("UICorner", Notif).CornerRadius = UDim.new(0, 8)
    Instance.new("UIStroke", Notif).Color = Config.Theme.Accent
    
    Notif.Position = UDim2.new(0.5, -150, 1, 0)
