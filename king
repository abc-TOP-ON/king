--// Create UI Elements
local function CreateToggleButton(Name, Category, Setting)
    local Btn = Instance.new("TextButton", ScrollList)
    Btn.Size = UDim2.new(1, 0, 0, 35)
    Btn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    Btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    Btn.Text = Name .. " : OFF"
    Btn.Font = Enum.Font.GothamSemibold
    Btn.TextSize = 13
    Instance.new("UICorner", Btn).CornerRadius = UDim.new(0, 6)
    
    Btn.MouseButton1Click:Connect(function()
        Config[Category][Setting] = not Config[Category][Setting]
        local Status = Config[Category][Setting] and "ON" or "OFF"
        Notify(Name .. " : " .. Status)
        
        if Config[Category][Setting] then
            Btn.BackgroundColor3 = Config.Theme.Accent
            Btn.TextColor3 = Color3.fromRGB(0, 0, 0)
            Btn.Text = Name .. " : ✅ ON"
        else
            Btn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
            Btn.TextColor3 = Color3.fromRGB(255, 255, 255)
            Btn.Text = Name .. " : ❌ OFF"
        end
    end)
end

local function CreateSlider(Name, Category, Setting, Min, Max, Default)
    local Frame = Instance.new("Frame", ScrollList)
    Frame.Size = UDim2.new(1, 0, 0, 50)
    Frame.BackgroundTransparency = 1
    
    local Label = Instance.new("TextLabel", Frame)
    Label.Size = UDim2.new(1, 0, 0, 20)
    Label.BackgroundTransparency = 1
    Label.Text = Name .. ": " .. tostring(Default)
    Label.TextColor3 = Color3.new(1,1,1)
    Label.TextSize = 12
    Label.Font = Enum.Font.GothamSemibold
    
    local Slider = Instance.new("TextButton", Frame)
    Slider.Size = UDim2.new(1, 0, 0, 20)
    Slider.Position = UDim2.new(0, 0, 0.6, 0)
    Slider.BackgroundColor3 = Color3.fromRGB(40,40,40)
    Instance.new("UICorner", Slider).CornerRadius = UDim.new(0, 4)
    
    local Fill = Instance.new("Frame", Slider)
    Fill.Size = UDim2.new((Default-Min)/(Max-Min), 0, 1, 0)
    Fill.BackgroundColor3 = Config.Theme.Accent
    Instance.new("UICorner", Fill).CornerRadius = UDim.new(0, 4)
    
    Slider.MouseButton1Down:Connect(function()
        local MoveConn, ReleaseConn
        
        MoveConn = UserInputService.InputChanged:Connect(function(Input)
            if Input.UserInputType == Enum.UserInputType.MouseMovement then
                local X = math.clamp((Input.Position.X - Slider.AbsolutePosition.X) / Slider.AbsoluteSize.X, 0, 1)
                local Value = math.floor((X * (Max - Min)) + Min)
                Config[Category][Setting] = Value
                Fill.Size = UDim2.new(X, 0, 1, 0)
                Label.Text = Name .. ": " .. tostring(Value)
                
                if Setting == "FOV" and FOVCircle then
                    FOVCircle.Size = UDim2.new(0, Value * 2, 0, Value * 2)
                end
            end
        end)
        
        ReleaseConn = UserInputService.InputEnded:Connect(function(Input)
            if Input.UserInputType == Enum.UserInputType.MouseButton1 then
                MoveConn:Disconnect()
                ReleaseConn:Disconnect()
            end
        end)
    end)
end

