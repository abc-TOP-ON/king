local function GetTeamColor(Player)
    if Player.Team == LocalPlayer.Team and Config.Combat.CheckTeam then
        return Color3.fromRGB(0, 255, 0)
    else
        return Color3.fromRGB(255, 0, 0)
    end
end

local function HandleVisuals(P)
    local Bones = {}
    for i = 1, #SkeletonBones do
        local Line = Drawing.new("Line")
        Line.Thickness = 1.5
        Line.Color = Config.ESPColors.Skeleton
        Line.Transparency = 0.8
        Line.Visible = false
        table.insert(Bones, Line)
    end

    local Tracer = Drawing.new("Line")
    Tracer.Thickness = 1
    Tracer.Color = Config.ESPColors.Tracer
    Tracer.Transparency = 0.6
    Tracer.Visible = false

    local Hitboxes = {}

    local function Setup(Char)
        local Root = Char:WaitForChild("HumanoidRootPart", 10)
        local Hum = Char:WaitForChild("Humanoid", 10)
        
        local BGui = Instance.new("BillboardGui", Root)
        BGui.Size = UDim2.new(4, 0, 6.5, 0)
        BGui.AlwaysOnTop = true
        
        local Box = Instance.new("Frame", BGui)
        Box.Size = UDim2.new(1, 0, 1, 0)
        Box.BackgroundTransparency = 1
        local S = Instance.new("UIStroke", Box)
        S.Color = Config.ESPColors.Box
        S.Transparency = 0.5

        local Info = Instance.new("TextLabel", BGui)
        Info.Size = UDim2.new(1, 0, 0, 60)
        Info.Position = UDim2.new(0, 0, -0.6, 0)
        Info.BackgroundTransparency = 1
        Info.TextColor3 = Color3.new(1,1,1)
        Info.TextSize = 10
        Info.Font = Enum.Font.Code

        local HealthBar = Instance.new("Frame", BGui)
        HealthBar.Size = UDim2.new(1, 0, 0, 4)
        HealthBar.Position = UDim2.new(0, 0, 1.1, 0)
        HealthBar.BackgroundColor3 = Config.ESPColors.HealthBar
        Instance.new("UICorner", HealthBar).CornerRadius = UDim.new(0, 2)

        local Highlights = {}
        local function UpdateChams()
            for _, hl in pairs(Highlights) do hl:Destroy() end
            Highlights = {}
            if Config.Visuals.Chams then
                for _, part in pairs(Char:GetDescendants()) do
                    if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
                        local Highlight = Instance.new("Highlight", part)
                        Highlight.FillColor = GetTeamColor(P)
                        Highlight.FillTransparency = 0.4
                        Highlight.OutlineColor = Color3.new(1,1,1)
                        Highlight.OutlineTransparency = 0.3
                        table.insert(Highlights, Highlight)
                    end
                end
            end
        end

        local function UpdateHitboxes()
            for _, hb in pairs(Hitboxes) do hb:Destroy() end
            Hitboxes = {}
            if Config.Visuals.Hitbox then
                local HitboxParts = {"Head", "HumanoidRootPart", "LeftUpperArm", "RightUpperArm", "LeftUpperLeg", "RightUpperLeg"}
                for _, partName in pairs(HitboxParts) do
                    local Part = Char:FindFirstChild(partName)
                    if Part then
                        local BoxHandle = Instance.new("BoxHandleAdornment", Part)
                        BoxHandle.Size = Part.Size
                        BoxHandle.Color3 = Color3.fromRGB(255, 0, 0)
                        BoxHandle.Transparency = 0.5
                        BoxHandle.AlwaysOnTop = true
                        BoxHandle.ZIndex = 10
                        BoxHandle.Adornee = Part
                        table.insert(Hitboxes, BoxHandle)
                    end
                end
            end
        end

        RunService.RenderStepped:Connect(function()
            FOVCircle.Visible = Config.Visuals.FOV
            Radar.Visible = Config.Visuals.Radar
            Box.Visible = Config.Visuals.Box
            Info.Visible = Config.Visuals.Info
            HealthBar.Visible = Config.Visuals.HealthBar

            -- Update FOV Color
            if Config.Combat.Aimbot or Config.Combat.SilentAim then
                local T = GetTarget()
                if T then
                    FOVStroke.Color = Color3.fromRGB(255, 0, 0)
                else
                    FOVStroke.Color = Config.Theme.Accent
                end
            end

            if Root and Root.Parent and Hum.Health > 0 then
                local Pos, OnScreen = Camera:WorldToViewportPoint(Root.Position)
                
                local TeamColor = GetTeamColor(P)
                S.Color = TeamColor
                Tracer.Color = TeamColor
                HealthBar.BackgroundColor3 = TeamColor
                for _, line in pairs(Bones) do
                    line.Color = TeamColor
                end
                
                if Config.Visuals.HealthBar then
                    local HealthPercent = Hum.Health / Hum.MaxHealth
                    HealthBar.Size = UDim2.new(HealthPercent, 0, 0, 4)
                    HealthBar.BackgroundColor3 = Color3.fromRGB(255 * (1 - HealthPercent), 255 * HealthPercent, 0)
                end

                if Config.Visuals.Info and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                    local Dist = math.floor((Root.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude)
                    local GunText = ""
                    if Config.Visuals.GunESP then
                        local Tool = P.Character:FindFirstChildOfClass("Tool")
                        if Tool then
                            GunText = "\n🔫 " .. Tool.Name
                        end
                    end
                    Info.Text = string.format("%s\n❤️ %s HP | 📏 %sm%s", P.Name, math.floor(Hum.Health), Dist, GunText)
                end

                if OnScreen and Config.Visuals.Tracers then
                    Tracer.From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
                    Tracer.To = Vector2.new(Pos.X, Pos.Y)
                    Tracer.Visible = true
                else
                    Tracer.Visible = false
                end

                if Config.Visuals.Skeleton then
                    for i, connection in ipairs(SkeletonBones) do
                        local Part1 = Char:FindFirstChild(connection[1])
                        local Part2 = Char:FindFirstChild(connection[2])
                        
                        if Part1 and Part2 then
                            local P1, Vis1 = Camera:WorldToViewportPoint(Part1.Position)
                            local P2, Vis2 = Camera:WorldToViewportPoint(Part2.Position)
                            
                            if Vis1 or Vis2 then
                                Bones[i].From = Vector2.new(P1.X, P1.Y)
                                Bones[i].To = Vector2.new(P2.X, P2.Y)
                                Bones[i].Visible = true
                            else
                                Bones[i].Visible = false
                            end
                        else
                            Bones[i].Visible = false
                        end
                    end
                else
                    for _, line in pairs(Bones) do line.Visible = false end
                end

                UpdateChams()
                UpdateHitboxes()

                -- Radar Update
                if Config.Visuals.Radar then
                    for _, child in pairs(Radar:GetChildren()) do
                        if child:IsA("Frame") then child:Destroy() end
                    end
                    
                    for _, v in pairs(Players:GetPlayers()) do
                        if v ~= LocalPlayer and v ~= P then
                            local VChar = v.Character
                            if VChar and VChar:FindFirstChild("HumanoidRootPart") then
                                local RelativePos = VChar.HumanoidRootPart.Position - (LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") and LocalPlayer.Character.HumanoidRootPart.Position or Vector3.new())
                                local Angle = math.atan2(RelativePos.X, RelativePos.Z)
                                local Dist = math.clamp(RelativePos.Magnitude / 200, 0, 2)
                                
                                local Dot = Instance.new("Frame", Radar)
                                Dot.Size = UDim2.new(0, 5, 0, 5)
                                Dot.Position = UDim2.new(0.5 + math.sin(Angle) * Dist/2, 0, 0.5 + math.cos(Angle) * Dist/2, 0)
                                Dot.AnchorPoint = Vector2.new(0.5, 0.5)
                                Dot.BackgroundColor3 = GetTeamColor(v)
                                Instance.new("UICorner", Dot).CornerRadius = UDim.new(1, 0)
                            end
                        end
                    end
                end
            else
                Tracer.Visible = false
                for _, line in pairs(Bones) do line.Visible = false end
            end
        end)
    end
    P.CharacterAdded:Connect(Setup)
    if P.Character then Setup(P.Character) end
end

